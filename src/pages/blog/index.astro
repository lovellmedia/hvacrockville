---
import SEOHead from '../../components/SEOHead.astro';
---
<!doctype html>
<html lang="en">
<head>
  <SEOHead title="HVAC and AC Repair Resources - HVAC Rockville" description="Helpful guides for Rockville homeowners comparing symptoms, timing, and service options." />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script>
    (function() {
      const theme = localStorage.getItem('theme-preference');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>
<body>

  <div class="emergency-strip">
    <span class="inline-flex items-center gap-2">
      <span class="relative flex h-2 w-2"><span class="ping-dot"></span></span>
      Same-Day HVAC & AC Repair in Rockville - Call Now: <a href="tel:2405550148">(240) 555-0148</a>
    </span>
  </div>

  <header class="site-header is-transparent js-site-header">
    <div class="container">
      <div class="site-header-inner">
        <a href="/" class="logo">
          <div class="logo-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2 5 13h6l-2 9 10-13h-6L12 2Z" fill="white"/></svg></div>
          <div class="logo-text"><span class="logo-brand">HVAC Rockville</span></div>
        </a>
        <nav class="desktop-nav">
          <a href="/" class="nav-link">Home</a>
          <a href="/services/" class="nav-link">Services</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/" class="nav-link is-active">Blog</a>
          <a href="/glossary/" class="nav-link">Glossary</a>
          <a href="/contact/" class="nav-link">Contact</a>
        </nav>
        <div class="header-actions">
          <a href="tel:2405550148" class="header-phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>(240) 555-0148</span>
          </a>
          <button class="theme-toggle js-theme-toggle" aria-label="Toggle theme">
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <a href="/contact/" class="header-cta">Request HVAC Repair</a>
          <button class="mobile-menu-btn js-mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu" aria-expanded="false" aria-controls="mobile-menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="mobile-menu js-mobile-menu" id="mobile-menu">
      <div class="mobile-menu-inner">
        <a href="/" class="mobile-menu-link">Home</a>
        <a href="/services/" class="mobile-menu-link">Services</a>
        <a href="/about/" class="mobile-menu-link">About</a>
        <a href="/" class="mobile-menu-link is-active">Blog</a>
        <a href="/glossary/" class="mobile-menu-link">Glossary</a>
        <a href="/contact/" class="mobile-menu-link">Contact</a>
        <div class="mobile-menu-footer">
          <a href="tel:2405550148" style="color: white; display: flex; align-items: center; gap: 0.5rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>(240) 555-0148</span>
          </a>
        </div>
        <a href="/contact/" class="mobile-menu-cta">Request HVAC Repair</a>
      </div>
    </div>
  </header>

  <main>
    <section class="hero hero-45">
      <div class="hero-bg">
        <img src="/images/hero-home.png" alt="HVAC Rockville blog" loading="eager">
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <div class="container">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
              <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <a href="/" class="breadcrumb-link" itemprop="item"><span itemprop="name">Home</span></a>
                <meta itemprop="position" content="1">
              </li>
              <li class="breadcrumb-separator">/</li>
              <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <span class="breadcrumb-current" itemprop="name">Blog</span>
                <meta itemprop="position" content="2">
              </li>
            </ol>
          </nav>
          <h1 class="hero-headline">HVAC and AC Repair Resources</h1>
          <p class="hero-subheadline">Helpful guides for Rockville homeowners comparing symptoms, timing, and service options.</p>
        </div>
      </div>
    </section>

    <section class="section section-md section-bg-light">
      <div class="container">
        <div class="category-pills js-animate animate-on-scroll">
          <button class="category-pill js-category-pill is-active">All</button>
          <button class="category-pill js-category-pill">Signs</button>
          <button class="category-pill js-category-pill">Prevention</button>
          <button class="category-pill js-category-pill">Safety</button>
          <button class="category-pill js-category-pill">Costs</button>
          <button class="category-pill js-category-pill">DIY Tips</button>
        </div>
      </div>
    </section>

    <section class="section section-lg section-bg-light" style="padding-top: 0;">
      <div class="container">
        <div class="blog-grid blog-grid-2">
          <article class="blog-card blog-card-featured js-animate animate-on-scroll">
            <div class="blog-card-image">
              <img src="/images/blog-01.png" alt="HVAC and AC Repair: When to Call a Pro" loading="lazy">
              <span class="blog-card-category">Signs</span>
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta">Dec 15, 2024 - By Rockville Service Team</div>
              <h3 class="blog-card-title">HVAC and AC Repair: When to Call a Pro</h3>
              <p class="blog-card-excerpt">Learn the practical signs that it is time to schedule hvac and ac repair service and what information helps the visit go smoothly.</p>
              <a href="/blog/post/" class="blog-card-link">Read More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </article>
          <article class="blog-card js-animate animate-on-scroll" data-category="Prevention">
            <div class="blog-card-image"><img src="/images/blog-02.png" alt="How to Prevent hvac repair requests From Entering Your Home" loading="lazy"><span class="blog-card-category">Prevention</span></div>
            <div class="blog-card-body">
              <div class="blog-card-meta">Dec 10, 2024 - By Sarah Williams</div>
              <h3 class="blog-card-title">How to Prevent hvac repair requests From Entering Your Home</h3>
              <p class="blog-card-excerpt">Practical prevention tips every homeowner should know to keep hvac repair requests out for good.</p>
              <a href="/blog/post/" class="blog-card-link">Read More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </article>
          <article class="blog-card js-animate animate-on-scroll" data-category="Safety">
            <div class="blog-card-image"><img src="/images/blog-03.png" alt="Are hvac repair requests Dangerous?" loading="lazy"><span class="blog-card-category">Safety</span></div>
            <div class="blog-card-body">
              <div class="blog-card-meta">Dec 5, 2024 - By Mike Johnson</div>
              <h3 class="blog-card-title">Are hvac repair requests Dangerous? A Complete Safety Guide</h3>
              <p class="blog-card-excerpt">Understanding the real risks and how to protect your family safely and effectively.</p>
              <a href="/blog/post/" class="blog-card-link">Read More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </article>
          <article class="blog-card js-animate animate-on-scroll" data-category="Costs">
            <div class="blog-card-image"><img src="/images/blog-04.png" alt="HVAC Repair Cost Breakdown" loading="lazy"><span class="blog-card-category">Costs</span></div>
            <div class="blog-card-body">
              <div class="blog-card-meta">Nov 28, 2024 - By Sarah Williams</div>
              <h3 class="blog-card-title">HVAC Repair Cost Breakdown: What to Expect in </h3>
              <p class="blog-card-excerpt">Transparent pricing guide. Know what you're paying for before you hire.</p>
              <a href="/blog/post/" class="blog-card-link">Read More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </article>
          <article class="blog-card js-animate animate-on-scroll" data-category="DIY Tips">
            <div class="blog-card-image"><img src="/images/blog-05.png" alt="DIY vs Professional HVAC Repair" loading="lazy"><span class="blog-card-category">DIY Tips</span></div>
            <div class="blog-card-body">
              <div class="blog-card-meta">Nov 20, 2024 - By Mike Johnson</div>
              <h3 class="blog-card-title">DIY vs Professional HVAC Repair: When to Call the Pros</h3>
              <p class="blog-card-excerpt">Know when you can handle it yourself and when it's time to bring in experts.</p>
              <a href="/blog/post/" class="blog-card-link">Read More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </article>
          <article class="blog-card js-animate animate-on-scroll" data-category="Signs">
            <div class="blog-card-image"><img src="/images/blog-06.png" alt="Seasonal hvac repair requests Activity" loading="lazy"><span class="blog-card-category">Signs</span></div>
            <div class="blog-card-body">
              <div class="blog-card-meta">Nov 15, 2024 - By Sarah Williams</div>
              <h3 class="blog-card-title">Seasonal hvac repair requests Activity: What to Watch For Year-Round</h3>
              <p class="blog-card-excerpt">Understanding seasonal patterns helps you stay ahead of potential problems.</p>
              <a href="/blog/post/" class="blog-card-link">Read More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </article>
        </div>
        <div class="pagination">
          <a href="#" class="pagination-link pagination-prev is-disabled"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>Previous</a>
          <div class="pagination-numbers">
            <a href="#" class="pagination-number is-active">1</a>
            <a href="#" class="pagination-number">2</a>
            <a href="#" class="pagination-number">3</a>
          </div>
          <a href="#" class="pagination-link pagination-next">Next<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo">
            <div class="logo-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2 5 13h6l-2 9 10-13h-6L12 2Z" fill="white"/></svg></div>
            <div class="logo-text"><span class="logo-brand">HVAC Rockville</span></div>
          </a>
          <p>HVAC and AC Repair specialists serving Rockville homes with clear communication and practical service options since 2014.</p>
          <div class="footer-contact">
            <a href="tel:2405550148"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg><span>(240) 555-0148</span></a>
            <div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span>199 E Montgomery Ave, Rockville, MD 20850</span></div>
          </div>
        </div>
        <div class="footer-column">
          <h3>Services</h3>
          <ul>
            <li><a href="/services/">AC Repair</a></li>
            <li><a href="/services/">Furnace Repair</a></li>
            <li><a href="/services/">Heat Pump Service</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h3>Company</h3>
          <ul>
            <li><a href="/about/">About</a></li>
            <li><a href="/">Blog</a></li>
            <li><a href="/glossary/">Glossary</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
        </div>
        <div class="footer-areas">
          <h3>Service Areas</h3>
          <div class="footer-area-tags">
            <span class="footer-area-tag">Rockville</span>
            <span class="footer-area-tag">North Bethesda</span>
            <span class="footer-area-tag">Potomac</span>
            <span class="footer-area-tag">Gaithersburg</span>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-legal">2026 HVAC Rockville. All rights reserved. Licensed & insured where required.</div>
        <div class="footer-social">
          <a href="https://facebook.com/hvacrockville" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
          <a href="https://twitter.com/hvacrockville" aria-label="Twitter"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg></a>
        </div>
      </div>
    </div>
  </footer>

  <a href="tel:2405550148" class="fab" aria-label="Call now">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
  </a>

  <div class="cookie-banner js-cookie-banner hidden">
    <div class="cookie-banner-inner">
      <p>We use cookies to improve your experience. By continuing, you agree to our use of cookies.</p>
      <button class="cookie-banner-close js-cookie-close" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <button class="cookie-banner-btn js-cookie-accept">Got it</button>
  </div>

  <script is:inline src="/js/main.js"></script>
</body>
</html>