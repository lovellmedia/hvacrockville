---
import SEOHead from '../components/SEOHead.astro';
---
<!doctype html>
<html lang="en">
<head>
  <SEOHead title="HVAC Rockville - Fast Heating & AC Repair in Rockville" description="Rockville HVAC and AC repair for no-cooling calls, furnace problems, heat pump issues, weak airflow, and urgent comfort system failures." />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script>
    (function() {
      const theme = localStorage.getItem('theme-preference');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>
<body>

  <!-- Emergency Strip -->
  <div class="emergency-strip">
    <span class="inline-flex items-center gap-2">
      <span class="relative flex h-2 w-2"><span class="ping-dot"></span></span>
      Same-Day HVAC & AC Repair in Rockville - Call Now: <a href="tel:2405550148">(240) 555-0148</a>
    </span>
  </div>

  <!-- Site Header -->
  <header class="site-header is-transparent js-site-header">
    <div class="container">
      <div class="site-header-inner">
        <a href="/" class="logo">
          <div class="logo-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2 5 13h6l-2 9 10-13h-6L12 2Z" fill="white"/></svg></div>
          <div class="logo-text">
            <span class="logo-brand">HVAC Rockville</span>
          </div>
        </a>
        <nav class="desktop-nav">
          <a href="/" class="nav-link is-active">Home</a>
          <a href="/services/" class="nav-link">Services</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/blog/" class="nav-link">Blog</a>
          <a href="/glossary/" class="nav-link">Glossary</a>
          <a href="/contact/" class="nav-link">Contact</a>
        </nav>
        <div class="header-actions">
          <a href="tel:2405550148" class="header-phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>(240) 555-0148</span>
          </a>
          <button class="theme-toggle js-theme-toggle" aria-label="Toggle theme">
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <a href="/contact/" class="header-cta">Request HVAC Repair</a>
          <button class="mobile-menu-btn js-mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu" aria-expanded="false" aria-controls="mobile-menu" aria-expanded="false" aria-controls="mobile-menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="mobile-menu js-mobile-menu" id="mobile-menu">
      <div class="mobile-menu-inner">
        <a href="/" class="mobile-menu-link is-active">Home</a>
        <a href="/services/" class="mobile-menu-link">Services</a>
        <a href="/about/" class="mobile-menu-link">About</a>
        <a href="/blog/" class="mobile-menu-link">Blog</a>
        <a href="/glossary/" class="mobile-menu-link">Glossary</a>
        <a href="/contact/" class="mobile-menu-link">Contact</a>
        <div class="mobile-menu-footer">
          <a href="tel:2405550148" style="color: white; display: flex; align-items: center; gap: 0.5rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>(240) 555-0148</span>
          </a>
        </div>
        <a href="/contact/" class="mobile-menu-cta">Request HVAC Repair</a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero hero-full">
      <div class="hero-bg">
        <img src="/images/hero-home.png" alt="HVAC Rockville technician at work" loading="eager">
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <div class="container">
          <h1 class="hero-headline">HVAC & AC Repair<br>in Rockville</h1>
          <p class="hero-subheadline">Fast diagnostics, practical repairs, and clear next steps for Rockville homes dealing with no AC, no heat, weak airflow, or system alarms.</p>
          <div class="hero-buttons">
            <a href="/contact/" class="btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Request HVAC Repair
            </a>
            <a href="tel:2405550148" class="btn-outline">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              (240) 555-0148
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="trust-bar section-bg-light">
      <div class="container">
        <div class="trust-grid">
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <div class="trust-value">Insured</div>
              <div class="trust-label">Local Service</div>
            </div>
          </div>
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="trust-value">Fast</div>
              <div class="trust-label">Dispatch</div>
            </div>
          </div>
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <div>
              <div class="trust-value">Clear</div>
              <div class="trust-label">Quotes</div>
            </div>
          </div>
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
            </div>
            <div>
              <div class="trust-value">Trusted</div>
              <div class="trust-label">Rockville Pros</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="section section-lg section-bg-light">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-heading js-animate animate-on-scroll">HVAC Repair Services in Rockville</h2>
          <p class="section-subheading js-animate animate-on-scroll">Focused hvac and ac repair support for Rockville homeowners who want responsive help, clear scope, and no vague next steps.</p>
        </div>
        <div class="service-grid service-grid-3 stagger-children">
          <div class="service-card js-animate animate-on-scroll">
            <div class="service-card-image">
              <img src="/images/service-ac-repair.png" alt="AC Repair" loading="lazy">
            </div>
            <div class="service-card-body">
              <div class="service-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              </div>
              <h3 class="service-card-title">AC Repair</h3>
              <p class="service-card-desc">Cooling diagnostics for warm air, frozen coils, tripped breakers, failed capacitors, and outdoor unit problems.</p>
              <a href="/services/" class="service-card-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
          <div class="service-card js-animate animate-on-scroll">
            <div class="service-card-image">
              <img src="/images/service-furnace-repair.png" alt="Furnace Repair" loading="lazy">
            </div>
            <div class="service-card-body">
              <div class="service-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.5 2 6 4.5 6 7C6 9.5 8 11 8 11L6 13L9 12C9 12 10 14 12 14C14 14 15 12 15 12L18 13L16 11C16 11 18 9.5 18 7C18 4.5 15.5 2 12 2Z"/><path d="M8 15C8 15 6 17 4 16C4 16 5 18 8 18V15Z"/><path d="M16 15C16 15 18 17 20 16C20 16 19 18 16 18V15Z"/></svg>
              </div>
              <h3 class="service-card-title">Furnace Repair</h3>
              <p class="service-card-desc">Heating repair for ignition failures, short cycling, blower problems, and unsafe shutdowns during cold snaps.</p>
              <a href="/services/" class="service-card-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
          <div class="service-card js-animate animate-on-scroll">
            <div class="service-card-image">
              <img src="/images/service-heat-pump.png" alt="Heat Pump Service" loading="lazy">
            </div>
            <div class="service-card-body">
              <div class="service-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="service-card-title">Heat Pump Service</h3>
              <p class="service-card-desc">Repair support for heat pumps, auxiliary heat problems, reversing valve symptoms, and seasonal performance drops.</p>
              <a href="/services/" class="service-card-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
          <div class="service-card js-animate animate-on-scroll">
            <div class="service-card-image">
              <img src="/images/service-emergency.png" alt="Emergency HVAC" loading="lazy">
            </div>
            <div class="service-card-body">
              <div class="service-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              </div>
              <h3 class="service-card-title">Emergency HVAC</h3>
              <p class="service-card-desc">Priority response when indoor temperatures are unsafe, equipment is making alarming sounds, or comfort is falling fast.</p>
              <a href="/services/" class="service-card-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
          <div class="service-card js-animate animate-on-scroll">
            <div class="service-card-image">
              <img src="/images/service-airflow.png" alt="Airflow Diagnostics" loading="lazy">
            </div>
            <div class="service-card-body">
              <div class="service-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="service-card-title">Airflow Diagnostics</h3>
              <p class="service-card-desc">Duct, filter, blower, and vent checks that identify why rooms feel uneven or the system strains to keep up.</p>
              <a href="/services/" class="service-card-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
          <div class="service-card js-animate animate-on-scroll">
            <div class="service-card-image">
              <img src="/images/service-thermostat.png" alt="Thermostat & Controls" loading="lazy">
            </div>
            <div class="service-card-body">
              <div class="service-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <h3 class="service-card-title">Thermostat & Controls</h3>
              <p class="service-card-desc">Troubleshooting for bad readings, wiring faults, smart thermostat issues, and systems that will not respond.</p>
              <a href="/services/" class="service-card-link">Learn More <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="section section-lg section-bg-dark">
      <div class="container">
        <div class="stat-grid">
          <div class="stat-item js-animate animate-on-scroll">
            <div class="stat-value">4.9</div>
            <div class="stat-label">Average Rating</div>
          </div>
          <div class="stat-item js-animate animate-on-scroll">
            <div class="stat-value">24/7</div>
            <div class="stat-label">Urgent Response</div>
          </div>
          <div class="stat-item js-animate animate-on-scroll">
            <div class="stat-value">Rockville</div>
            <div class="stat-label">Local Service</div>
          </div>
          <div class="stat-item js-animate animate-on-scroll">
            <div class="stat-value">10+</div>
            <div class="stat-label">Years Experience</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Process Section -->
    <section class="section section-lg section-bg-light">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-heading js-animate animate-on-scroll">How Service Works</h2>
          <p class="section-subheading js-animate animate-on-scroll">A simple process that keeps your hvac and ac repair request moving from first call to completed visit.</p>
        </div>
        <div class="process-grid">
          <div class="process-step js-animate animate-on-scroll">
            <div class="process-step-number"><span>1</span></div>
            <h3 class="process-step-title">Describe the Symptoms</h3>
            <p class="process-step-desc">A technician starts with what changed, what you hear, and how the system is behaving.</p>
          </div>
          <div class="process-step js-animate animate-on-scroll">
            <div class="process-step-number"><span>2</span></div>
            <h3 class="process-step-title">Diagnose the Failure</h3>
            <p class="process-step-desc">Electrical, airflow, refrigerant, and mechanical checks isolate the cause before repair work begins.</p>
          </div>
          <div class="process-step js-animate animate-on-scroll">
            <div class="process-step-number"><span>3</span></div>
            <h3 class="process-step-title">Repair and Stabilize</h3>
            <p class="process-step-desc">You get repair options, system testing, and prevention guidance before the visit wraps.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Lead Form CTA -->
    <section class="section section-lg section-bg-light">
      <div class="container">
        <div class="lead-form lead-form-fullwidth js-animate animate-on-scroll">
          <h3 class="lead-form-heading">Request HVAC and AC Repair Service</h3>
          <p class="lead-form-subheading">Send the basics and get a clear next step for your Rockville service request.</p>
          <form class="js-lead-form" novalidate>
            <div class="form-grid form-grid-2">
              <div class="form-field">
                <label>Full Name <span class="required">*</span></label>
                <input type="text" placeholder="John Smith" data-required data-label="Full name">
              </div>
              <div class="form-field">
                <label>Phone <span class="required">*</span></label>
                <input type="tel" placeholder="(555) 000-0000" data-required data-label="Phone">
              </div>
              <div class="form-field">
                <label>Email</label>
                <input type="email" placeholder="john@email.com">
              </div>
              <div class="form-field">
                <label>City <span class="required">*</span></label>
                <input type="text" placeholder="Your city" data-required data-label="City">
              </div>
              <div class="form-field" style="grid-column: 1 / -1;">
                <label>How can we help?</label>
                <textarea rows="3" placeholder="Describe your situation..."></textarea>
              </div>
            </div>
            <button type="submit" class="form-submit js-form-submit" style="margin-top: 1rem;">Request HVAC Repair</button>
            <p class="form-trust-note">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Clear scope. Local service. No pressure.
            </p>
            <div class="form-success hidden js-form-success">
              <div class="form-success-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <h3>Thank You!</h3>
              <p>We've received your request and will contact you within 30 minutes.</p>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Before/After -->
    <section class="section section-lg section-bg-light">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-heading js-animate animate-on-scroll">HVAC and AC Repair Results</h2>
          <p class="section-subheading js-animate animate-on-scroll">A service experience built around clear expectations and finished details.</p>
        </div>
        <div class="ba-slider js-ba-slider js-animate animate-on-scroll">
          <div class="ba-image-wrapper">
            <img src="/images/before.png" alt="Before HVAC Repair" class="ba-image-before">
            <img src="/images/after.png" alt="After HVAC Repair" class="ba-image-after">
          </div>
          <div class="ba-handle js-ba-handle">
            <div class="ba-handle-line"></div>
            <div class="ba-handle-button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
          </div>
          <span class="ba-label ba-label-before">Before</span>
          <span class="ba-label ba-label-after">After</span>
        </div>
      </div>
    </section>

    <!-- Reviews Carousel -->
    <section class="review-section">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-heading js-animate animate-on-scroll">What Rockville Customers Say</h2>
          <p class="section-subheading js-animate animate-on-scroll">Feedback from homeowners who wanted responsive hvac and ac repair help without confusion.</p>
        </div>
        <div class="js-review-carousel">
          <div class="js-review-slide">
            <div class="review-card">
