---
import SEOHead from '../../components/SEOHead.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <SEOHead title="HVAC Repair Glossary | HVAC Rockville" description="Plain-English hvac repair terms for Rockville homeowners." />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/theme.css">
  </head>
  <body>
    <div class="emergency-strip">Same-Day HVAC & AC Repair in Rockville - Call Now: <a href="tel:2405550148">(240) 555-0148</a></div>
    <header class="site-header">
      <div class="container">
        <div class="site-header-inner">
          <a href="/" class="logo"><div class="logo-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" fill="white"/></svg></div><div class="logo-text"><span class="logo-brand">HVAC Rockville</span></div></a>
          <nav class="desktop-nav">
            <a href="/" class="nav-link">Home</a>
            <a href="/services/" class="nav-link">Services</a>
            <a href="/about/" class="nav-link">About</a>
            <a href="/blog/" class="nav-link">Blog</a>
            <a href="/glossary/" class="nav-link">Glossary</a>
            <a href="/contact/" class="nav-link">Contact</a>
          </nav>
          <div class="header-actions"><a href="tel:2405550148" class="header-phone"><span>(240) 555-0148</span></a><a href="/contact/" class="header-cta">Request HVAC Repair</a></div>
        </div>
      </div>
    </header>
    <main>
    <section class="hero hero-45"><div class="hero-bg"><img src="/images/hero-home.png" alt="HVAC Repair glossary" loading="eager"><div class="hero-overlay"></div></div><div class="hero-content"><div class="container"><h1 class="hero-headline">HVAC Repair Glossary</h1><p class="hero-subheadline">Plain-English terms for Rockville homeowners comparing service options and next steps.</p></div></div></section>
    <section class="section section-lg section-bg-light"><div class="container"><div class="glossary-terms-grid"><a href="/glossary/term/" class="glossary-term-card"><div class="glossary-term-header"><span class="glossary-term-name">Service Scope</span></div><p class="glossary-term-def">What the hvac repair visit includes, what it excludes, and what result the visit is meant to achieve.</p></a>
<a href="/glossary/term/" class="glossary-term-card"><div class="glossary-term-header"><span class="glossary-term-name">Problem Area</span></div><p class="glossary-term-def">The room, fixture, surface, system, or visible condition where the service request starts.</p></a>
<a href="/glossary/term/" class="glossary-term-card"><div class="glossary-term-header"><span class="glossary-term-name">Scheduling Window</span></div><p class="glossary-term-def">The appointment timing that matches urgency, access needs, and expected service length.</p></a>
<a href="/glossary/term/" class="glossary-term-card"><div class="glossary-term-header"><span class="glossary-term-name">Safety Risk</span></div><p class="glossary-term-def">Any condition that could create damage, contamination, comfort loss, or avoidable stress if ignored.</p></a>
<a href="/glossary/term/" class="glossary-term-card"><div class="glossary-term-header"><span class="glossary-term-name">Final Check</span></div><p class="glossary-term-def">The closing walkthrough or test that confirms the requested work is complete.</p></a>
<a href="/glossary/term/" class="glossary-term-card"><div class="glossary-term-header"><span class="glossary-term-name">Follow-Up</span></div><p class="glossary-term-def">Any recommended next step, maintenance note, or future service reminder after the visit.</p></a></div></div></section>
  </main>
    <footer class="site-footer">
      <div class="container">
        <div class="footer-bottom"><div class="footer-legal">2026 HVAC Rockville. All rights reserved.</div></div>
      </div>
    </footer>
    <script is:inline src="/js/main.js"></script>
  </body>
</html>
